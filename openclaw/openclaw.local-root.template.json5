{
  // Copy to runtime host config path, for example:
  //   /etc/openclaw/openclaw.json5
  //
  // Keep local/private file last so it overrides repo defaults when needed.
  // Replace __REPO_OPENCLAW_JSON_ABS_PATH__ with the repo's absolute path
  // on the host or inside the container.

  $include: [
    "__REPO_OPENCLAW_JSON_ABS_PATH__",
    "./openclaw.private.json5"
  ]
}
