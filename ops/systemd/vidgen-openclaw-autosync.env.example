# Optional local runtime overrides for vidgen-openclaw-autosync.service
# Copy to: /etc/default/vidgen-openclaw-autosync

# Repository drift handling strategy before pull/deploy:
# - stash (recommended): auto-stash local tracked/untracked changes and continue.
# - fail: abort deploy when local changes exist.
# - reset: hard reset/clean working tree (keeps a backup branch reference).
DIRTY_REPO_STRATEGY=stash

# Enable WhatsApp failure alerts from VPS autosync script.
# Note: WhatsApp delivery depends on OpenClaw gateway/device auth state.
WHATSAPP_ALERT_ENABLED=0

# OpenClaw message channel and target for WhatsApp alerts.
WHATSAPP_ALERT_CHANNEL=whatsapp
WHATSAPP_ALERT_TARGET=+10000000000

# Optional account label if your OpenClaw channel has multiple WhatsApp accounts.
# WHATSAPP_ALERT_ACCOUNT=default

# Optional message prefix.
WHATSAPP_ALERT_PREFIX=[vidgen-autosync]

# Minimum seconds between alert sends to avoid spam during repeated failures.
WHATSAPP_ALERT_MIN_INTERVAL_SEC=900

# Enable Telegram failure alerts from VPS autosync script.
# Telegram sends directly via bot API and does not depend on OpenClaw pairing.
TELEGRAM_ALERT_ENABLED=0

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Telegram chat id (user/group/channel id).
TELEGRAM_CHAT_ID=

# Optional message prefix.
TELEGRAM_ALERT_PREFIX=[vidgen-autosync]

# Minimum seconds between alert sends to avoid spam during repeated failures.
TELEGRAM_ALERT_MIN_INTERVAL_SEC=900
