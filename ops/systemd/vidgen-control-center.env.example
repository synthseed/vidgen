# Copy to /etc/default/vidgen-control-center
NODE_ENV=production
HOST=127.0.0.1
PORT=3210
CONTROL_CENTER_BASE_PATH=/control-center
OPENCLAW_WORKSPACE=/docker/openclaw-jnqf/data/repos/vidgen
# Keep aligned with build scripts (control_center_autoupdate.sh, vps_autosync_openclaw.sh)
CONTROL_CENTER_DIST_DIR=.next
# Set for private API access when exposed on tailnet
CONTROL_CENTER_API_TOKEN=replace-me
CONTROL_CENTER_RATE_LIMIT_CAPACITY=60
CONTROL_CENTER_RATE_LIMIT_REFILL_PER_SEC=1
CONTROL_CENTER_RATE_LIMIT_WINDOW_MS=60000
